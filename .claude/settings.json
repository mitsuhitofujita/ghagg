{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": "./plans",
  "enabledPlugins": {
  },
  "permissions": {
    "allow": [
      "Bash(ls -la *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.local/*)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git push *)"
    ]
  }
}